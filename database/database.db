
SET SQL_MODE = "NO_AUTO_VALUE_ON_ZERO";
START TRANSACTION;
SET time_zone = "+00:00";



CREATE TABLE `aforos` (
  `id` int(11) NOT NULL,
  `NombreTour` varchar(100) DEFAULT NULL,
  `CupoBase` varchar(100) DEFAULT NULL,
  `CupoDia` varchar(50) DEFAULT NULL,
  `FechaRegistro` varchar(50) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `categoriacliente`
--

CREATE TABLE `categoriacliente` (
  `Id_Categoria` int(11) NOT NULL,
  `Categoria` varchar(50) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `history`
--

CREATE TABLE `history` (
  `id` int(11) NOT NULL,
  `Id_Reserva` varchar(50) DEFAULT NULL,
  `Tipo` varchar(50) DEFAULT NULL,
  `Accion` varchar(50) DEFAULT NULL,
  `id_user` varchar(50) DEFAULT NULL,
  `FechaRegistro` varchar(50) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `horarios`
--

CREATE TABLE `horarios` (
  `id` int(11) NOT NULL,
  `Id_Punto` int(11) DEFAULT NULL,
  `Id_Tour` int(11) DEFAULT NULL,
  `HoraSalida` varchar(30) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `HoraLlegada` varchar(30) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL,
  `Ruta` varchar(3) CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `pasajeros`
--

CREATE TABLE `pasajeros` (
  `id` int(11) NOT NULL,
  `Id_Reserva` varchar(11) DEFAULT NULL,
  `NombrePasajero` varchar(100) DEFAULT NULL,
  `TipoPasajero` varchar(50) DEFAULT NULL,
  `IdPas` varchar(50) DEFAULT NULL,
  `TelefonoPasajero` varchar(50) DEFAULT NULL,
  `PrecioTour` varchar(50) DEFAULT NULL,
  `Comision` varchar(50) DEFAULT NULL,
  `Fecha` varchar(50) DEFAULT NULL,
  `Confirmacion` tinyint(1) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `pasajerostransfer`
--

CREATE TABLE `pasajerostransfer` (
  `id` int(11) DEFAULT NULL,
  `Id_Transfer` varchar(11) DEFAULT NULL,
  `NombrePasajero` varchar(100) DEFAULT NULL,
  `IdPas` varchar(50) DEFAULT NULL,
  `TelefonoPasajero` varchar(50) DEFAULT NULL,
  `Fecha` varchar(50) DEFAULT NULL,
  `Confirmacion` tinyint(1) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `puntos`
--

CREATE TABLE `puntos` (
  `Id_Punto` int(11) NOT NULL,
  `NombrePunto` varchar(100) DEFAULT NULL,
  `Sector` varchar(100) DEFAULT NULL,
  `Latitud` varchar(100) NOT NULL,
  `Longitud` varchar(100) NOT NULL,
  `Posicion` int(11) DEFAULT NULL,
  `Nuevo` tinyint(1) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `reservas`
--

CREATE TABLE `reservas` (
  `Id_Reserva` varchar(11) NOT NULL,
  `TipoReserva` varchar(50) NOT NULL,
  `NumeroPasajeros` varchar(10) DEFAULT NULL,
  `TotalPasajeros` int(11) DEFAULT NULL,
  `TourReserva` int(11) DEFAULT NULL,
  `PuntoEncuentro` varchar(200) DEFAULT NULL,
  `FechaReserva` varchar(50) DEFAULT NULL,
  `IdiomaReserva` varchar(10) DEFAULT NULL,
  `TelefonoReserva` varchar(50) DEFAULT NULL,
  `CategoriaReserva` int(11) DEFAULT NULL,
  `NombreReporta` varchar(50) DEFAULT NULL,
  `HoraSalida` varchar(50) DEFAULT NULL,
  `Ruta` varchar(2) DEFAULT NULL,
  `Observaciones` varchar(2000) DEFAULT NULL,
  `FechaRegistro` varchar(50) DEFAULT NULL,
  `Culminada` tinyint(1) NOT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `serviciotransfer`
--

CREATE TABLE `serviciotransfer` (
  `id` int(11) NOT NULL,
  `Servicio` varchar(100) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `tours`
--

CREATE TABLE `tours` (
  `Id_Tour` int(11) NOT NULL,
  `NombreTour` varchar(100) DEFAULT NULL,
  `Abreviacion` varchar(10) DEFAULT NULL,
  `PrecioAdulto` varchar(50) DEFAULT NULL,
  `PrecioNiño` varchar(50) DEFAULT NULL,
  `PrecioInfante` varchar(50) DEFAULT NULL,
  `Comision` varchar(50) DEFAULT NULL,
  `CupoBase` int(11) DEFAULT NULL,
  `CupoDia` int(11) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

--
-- Table structure for table `transfer`
--

CREATE TABLE `transfer` (
  `Id_Transfer` varchar(11) NOT NULL,
  `NumeroPasajeros` int(11) DEFAULT NULL,
  `Servicio` varchar(60) DEFAULT NULL,
  `Salida` varchar(300) DEFAULT NULL,
  `Llegada` varchar(300) DEFAULT NULL,
  `FechaTransfer` varchar(50) DEFAULT NULL,
  `NombreReporta` varchar(100) DEFAULT NULL,
  `HoraRecogida` varchar(30) DEFAULT NULL,
  `Vuelo` varchar(20) DEFAULT NULL,
  `TelefonoTransfer` varchar(50) DEFAULT NULL,
  `ValorServicio` varchar(50) DEFAULT NULL,
  `Observaciones` varchar(2000) DEFAULT NULL,
  `FechaRegistro` varchar(50) DEFAULT NULL,
  `Culminada` tinyint(1) DEFAULT NULL
) ENGINE=InnoDB DEFAULT CHARSET=utf8mb4 COLLATE=utf8mb4_general_ci;

-- --------------------------------------------------------

