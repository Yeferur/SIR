                function checkDuplicates() {
                    // Obtén todos los inputs con el nombre 'IdPas[]'
                    var ids = $('input[name="IdPas[]"]');
                    var values = [];
                    var duplicates = [];

                    // Recorre cada input y guarda su valor en un array
                    ids.each(function () {
                        var value = $(this).val().trim();
                        if (value) { // Solo considera los valores no vacíos
                            if (values.includes(value)) {
                                duplicates.push(value);
                            } else {
                                values.push(value);
                            }
                        }
                    });

                    // Si hay valores duplicados, puedes mostrar una alerta o hacer algo con ellos
                    if (duplicates.length > 0) {
                        $("#save-btn").attr("disabled", true);
                        swal({
                            title: "Cuidado",
                            text: "Los siguientes DNI/Pasaporte estan repetidos: " + duplicates.join(', '),
                            icon: "warning",
                        })
                    } else {
                        $("#save-btn").removeAttr("disabled");
                    }
                }

