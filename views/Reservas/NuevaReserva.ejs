<!DOCTYPE html>
<html lang="es">

<head>
    <title>Nueva Reserva</title>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>

    <style>
        #dropdown:checked,
        #dropdown:not(:checked) {
            position: absolute;
            left: -9999px;
            opacity: 0;
            pointer-events: none;
        }

        .dropdown:checked+label,
        .dropdown:not(:checked)+label {
            position: relative;
            font-weight: 500;
            font-size: 15px;
            line-height: 2;
            height: 40px;
            transition: all 200ms linear;
            border-radius: 4px;
            width: 100%;
            letter-spacing: 1px;
            display: -webkit-inline-flex;
            display: -ms-inline-flexbox;
            display: inline-flex;
            -webkit-align-items: center;
            -moz-align-items: center;
            -ms-align-items: center;
            align-items: center;
            -webkit-justify-content: center;
            -moz-justify-content: center;
            -ms-justify-content: center;
            justify-content: center;
            -ms-flex-pack: center;
            text-align: center;
            border: none;
            background-color: #1f2029;
            cursor: pointer;
            color: #c4c3ca;
        }

        .section-dropdown {
            position: absolute;
            padding: 5px;
            background-color: #111;
            margin: 10px;
            left: 0;
            max-width: 300px;
            border-radius: 4px;
            display: block;
            box-shadow: 0 14px 35px 0 rgba(9, 9, 12, 0.4);
            z-index: 2;
            opacity: 0;
            pointer-events: none;
            transform: translateY(20px);
            transition: all 200ms linear;
        }

        .dark-light:checked~.sec-center .section-dropdown {
            background-color: #fff;
            box-shadow: 0 14px 35px 0 rgba(9, 9, 12, 0.15);
        }

        .dropdown:checked~.section-dropdown {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        .section-dropdown:before {
            position: absolute;
            top: -20px;
            left: 0;
            width: 100%;
            height: 20px;
            content: '';
            display: block;
            z-index: 1;
        }

        .section-dropdown:after {
            position: absolute;
            top: -7px;
            left: 30px;
            width: 0;
            height: 0;
            border-left: 8px solid transparent;
            border-right: 8px solid transparent;
            border-bottom: 8px solid #111;
            content: '';
            display: block;
            z-index: 2;
            transition: all 200ms linear;
        }



        .form-styleCount {
            padding: 13px 20px;
            padding-left: 55px;
            margin-top: 5px;
            height: 48px;
            width: 100%;
            font-weight: 500;
            border-radius: 4px;
            font-size: 14px;
            line-height: 22px;
            letter-spacing: 0.5px;
            outline: none;
            color: #c4c3ca;
            background-color: #1f2029;
            border: none;
            -webkit-transition: all 200ms linear;
            transition: all 200ms linear;
            box-shadow: 0 4px 8px 0 rgba(21, 21, 21, .2);
        }

        .custom-btn {
            width: 60px;
            height: 40px;
            color: #fff;
            border-radius: 5px;
            padding: 10px 25px;
            font-family: 'Lato', sans-serif;
            font-weight: 500;
            background: transparent;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            display: inline-block;
            box-shadow: inset 2px 2px 2px 0px rgba(0, 0, 0, 0.5),
                7px 7px 20px 0px rgba(0, 0, 0, .1),
                4px 4px 5px 0px rgba(0, 0, 0, .1);
            outline: none;
        }

        .remove {
            background: rgb(240, 9, 9);
            background: linear-gradient(0deg, rgb(240, 9, 9) 0%, rgb(240, 5, 5) 100%);
            border: none;

        }

        .remove:before {
            height: 0%;
            width: 2px;
        }

        .remove:hover {
            box-shadow: 4px 4px 6px 0 rgb(45, 29, 29),
                -4px -4px 6px 0 rgb(45, 28, 28),
                inset -4px -4px 6px 0 rgba(255, 255, 255, .2),
                inset 4px 4px 6px 0 rgba(0, 0, 0, .4);
        }

        .btnn {
            background-color: #102770;
            color: #fff;
        }

        .icon-btn {
            width: 50px;
            height: 50px;
            border: 1px solid #1f2029;
            background: #1f2029;
            border-radius: 25px;
            overflow: hidden;
            position: relative;
            transition: width 0.2s ease-in-out;
            color: #fff;
        }

        .add-btn:hover {
            width: 120px;
        }

        .add-btn::before,
        .add-btn::after {
            transition: width 0.2s ease-in-out, border-radius 0.2s ease-in-out;
            content: "";
            position: absolute;
            height: 4px;
            width: 10px;
            top: calc(50% - 2px);
            background: red;
        }

        .plus::before,
        .plus::after {
            background: #66ff00;
        }

        .add-btn::after {
            right: 14px;
            overflow: hidden;
            border-top-right-radius: 2px;
            border-bottom-right-radius: 2px;
        }

        .add-btn::before {
            left: 14px;
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .icon-btn:focus {
            outline: none;
        }

        .btn-txt {
            opacity: 0;
            transition: opacity 0.2s;
            font-size: 13px;
        }

        .add-btn:hover::before,
        .add-btn:hover::after {
            width: 4px;
            border-radius: 2px;
        }

        .add-btn:hover .btn-txt {
            opacity: 1;
        }

        .add-icon::after,
        .add-icon::before {
            transition: all 0.2s ease-in-out;
            content: "";
            position: absolute;
            height: 20px;
            width: 2px;
            top: calc(50% - 10px);
            background: #66ff00;
            overflow: hidden;
        }

        .add-icon::before {
            left: 22px;
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .add-icon::after {
            right: 22px;
            border-top-right-radius: 2px;
            border-bottom-right-radius: 2px;
        }

        .add-btn:hover .add-icon::before {
            left: 15px;
            height: 4px;
            top: calc(50% - 2px);
        }

        .add-btn:hover .add-icon::after {
            right: 15px;
            height: 4px;
            top: calc(50% - 2px);
        }

        #search {
            top: 45px;
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        .search-container {
            position: relative;
        }

        .search-container .search {
            top: 70px;
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        #search::after {
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        #search::before {
            display: block;
            position: absolute;
            z-index: 1 !important;
        }

        #search::after {
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        .list-group-color {
            background: #1f2029;
            color: #fff;
        }

        .list-group-disabled-bg {
            background: #1f2029 !important;
            color: #fff !important;
        }

        .list-group-create-color {
            background: #1f2029;
            color: #45acdf;
        }

        .list-group-create-color:hover {
            background: #2a2f3a;
            color: #45acdf;
        }

        .list-group-color:hover,
        .list-group-disabled-color:hover {
            background: #2a2f3a;
            color: #fff;
        }

        /* Estilos para el modal */
        .modal {
            display: none;
            position: fixed;
            z-index: 1;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.4);
        }

        .modal-content {
            background-color: #2a2f3a;
            margin: 15% auto;
            padding: 20px;
            border: none;
        }

        .modal-header h2 {
            margin-top: 0;
        }

        .modal-body input {
            display: block;
            margin-bottom: 10px;
            padding: 10px;
        }

        .modal-footer {
            text-align: right;
        }

        .modal-footer button {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
        }

        .modal-footer button:hover {
            background-color: #45a049;
        }

        input.sw {
            opacity: 0;
            position: absolute;
            left: -9999px;
        }

        input.sw+label {
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
            transition: 0.2s ease;
            display: inline-block;
            height: 22px;
            /* Tamaño reducido */
            width: 40px;
            /* Tamaño reducido */
            position: relative;
            box-shadow: inset 0 0 0px 2px #e4e4e4;
            border-radius: 30px;
            /* Radio reducido */
            /* White toggle */
        }

        input.sw+label:before {
            content: "";
            position: absolute;
            display: block;
            height: 22px;
            /* Tamaño reducido */
            width: 22px;
            /* Tamaño reducido */
            top: 0;
            left: 0;
            border-radius: 11px;
            /* Radio reducido */
            background: rgba(76, 217, 100, 0);
            transition: 0.2s cubic-bezier(0.24, 0, 0.5, 1);
        }

        input.sw+label:after {
            content: "";
            position: absolute;
            display: block;
            height: 20px;
            /* Tamaño reducido */
            width: 20px;
            /* Tamaño reducido */
            top: 50%;
            margin-top: -10px;
            /* Ajustado para centrar */
            left: 1px;
            border-radius: 50%;
            /* Radio reducido */
            background: #fff;
            box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1), 0 4px 0px 0 rgba(0, 0, 0, 0.04), 0 4px 9px rgba(0, 0, 0, 0.13), 0 3px 3px rgba(0, 0, 0, 0.05);
            transition: 0.35s cubic-bezier(0.54, 1.6, 0.5, 1);
        }

        input.sw+label span {
            white-space: nowrap;
            height: 22px;
            /* Tamaño reducido */
            line-height: 22px;
            /* Ajustado para el nuevo tamaño */
            margin-left: 40px;
            /* Tamaño reducido */
            padding-left: 12px;
            /* Ajustado para el nuevo tamaño */
        }

        input.sw:checked+label:before {
            width: 40px;
            /* Tamaño reducido */
            background: #4cd964;
            transition: width 0.2s cubic-bezier(0, 0, 0, 0.1) !important;
        }

        input.sw:checked+label:after {
            left: 18px;
            /* Ajustado para el nuevo tamaño */
        }

        input.sw:checked+label {
            box-shadow: inset 0 0 0px 25px #e4e4e4;
            transition: box-shadow 2.5s cubic-bezier(0, 1.2, 0.94, 0.95);
        }
    </style>
</head>

<body>
    <main class="content">
        <div class="container-fluid p-0">
            <div class="container">
                <div class="card">
                    <div class="card-header">
                        <div class="input-group">
                            <h3 class="mb-0">
                                <strong>Registro de Reserva:</strong> &nbsp;&nbsp;&nbsp;
                            </h3>
                        </div>
                        <span style="font-size: 12px">Los campos con <span class="text-danger">*</span> son
                            obligatorios.</span>
                    </div>
                    <div class="card-body">
                        <form action="/NuevaReserva" method="POST" autocomplete="off">
                            <input type="hidden" name="Id_Reserva" id="Id_Reserva">

                            <% if (typeof user !="undefined" ){ %>
                                <input type="hidden" name="id_user" id="" value="<%=user.id_user %>">
                                <% } %>

                                    <div class="row">
                                        <div class="col-lg-3">
                                            <label class="fw-bold">Tipo de reserva</label>
                                            <select class="form-style" name="TipoReserva" id="TipoReserva"
                                                onchange="callCupos()">
                                                <option value="Grupal" selected>GRUPAL</option>
                                                <option value="Privada">PRIVADA</option>
                                            </select>
                                        </div>
                                        <div class="col-lg-3">
                                            <label class="fw-bold">Estado de la reserva</label>
                                            <select class="form-style" name="Estado" id="Estado">
                                                <option value="Activo" selected>ACTIVO</option>
                                                <option value="Pendiente">PENDIENTE</option>
                                            </select>
                                        </div>
                                    </div>
                                    <br>
                                    <div class="row">
                                        <div class="col-lg-3">
                                            <label class="fw-bold">Numero de Pasajeros <span
                                                    style="color: red">*</span></label>
                                            <input class="dropdown" type="checkbox" id="dropdown" name="dropdown" />
                                            <label class="for-dropdown" for="dropdown" id="numpas">0</label>
                                            <input type="hidden" name="input_numpas" id="input_numpas">
                                            <input type="hidden" name="total_pas" id="total_pas">
                                            <div class="section-dropdown">
                                                <div class="form-group">
                                                    <input type="text" name="adultos"
                                                        class="form-styleCount mayusculas " placeholder="Adultos"
                                                        id="adultos" onkeyup="total(); callCupos(); num_Pas();"
                                                        autocomplete="off" required>
                                                </div>
                                                <div class="form-group">
                                                    <input type="text" name="niños" class="form-styleCount mayusculas "
                                                        placeholder="Niños" id="niños"
                                                        onkeyup="total(); callCupos(); num_Pas();" autocomplete="off">
                                                </div>
                                                <div class="form-group">
                                                    <input type="text" name="infantes"
                                                        class="form-styleCount mayusculas " placeholder="Infantes"
                                                        id="infantes" onkeyup="total(); callCupos(); num_Pas();"
                                                        autocomplete="off">
                                                </div>
                                            </div>
                                        </div>
                                        <div class="col-lg-3">
                                            <label class="fw-bold">Elige el tour <span
                                                    style="color: red">*</span></label>
                                            <select class="form-style" name="SelectTour" id="SelectTour"
                                                onchange="select_Tour();" required>
                                                <option selected disabled>Seleccionar</option>
                                                <% if (typeof resultsTours !="undefined" ){
                                                    resultsTours.forEach((Tours)=>{ %>
                                                    <option value="<%= Tours.Id_Tour %>">
                                                        <%= Tours.NombreTour %>
                                                    </option>
                                                    <% }) } %>
                                            </select>

                                        </div>
                                        <div class="col-lg-3" id="punto">
                                            <label class="fw-bold">Puntos de encuentro <span
                                                    style="color: red">*</span></label>
                                            <div class="input-group mb-3">
                                                <input type="text" class="form-style mayusculas " placeholder=""
                                                    id="NombrePunto" name="NombrePunto" required>
                                                <input type="hidden" name="Id_Punto" id="Id_Punto">
                                            </div>
                                        </div>
                                        <div class="col-lg-3">
                                            <label class="fw-bold">Elige la fecha<span
                                                    style="color: red">*</span></label>
                                            <input type="date" class="form-style mayusculas " name="FechaReserva"
                                                id="FechaReserva" onchange="callCupos();" required />
                                        </div>
                                    </div>
                                    <div class="row">
                                        <div class="col-lg-3">
                                            <label class="fw-bold"># Tel. Reserva<span
                                                    style="color: red">*</span></label>
                                            <input type="text" class="form-style mayusculas " name="TelefonoReserva"
                                                id="TelefonoReserva" required autocomplete="off" />
                                        </div>
                                        <div class="col-lg-2">
                                            <label class="fw-bold">Idioma</label>
                                            <select class="form-style" name="IdiomaReserva">
                                                <option value="ESPAÑOL">ESPAÑOL</option>
                                                <option value="INGLÉS">INGLÉS</option>
                                            </select>
                                        </div>
                                        <div class="col-lg-2">
                                            <label class="fw-bold">Categoría</label>
                                            <select class="selectpicker form-style" title="Seleccionar" name="Categoria"
                                                id="Categoria" onchange="call_Load_Comision();">
                                                <% if(typeof resultsCategoria !="undefined" ){
                                                    resultsCategoria.forEach((Categoria)=>{ %>
                                                    <option value="<%= Categoria.Id_Categoria %>">
                                                        <%= Categoria.Categoria %>
                                                    </option>
                                                    <% }) }%>
                                            </select>
                                        </div>
                                        <div class="col-lg-2">
                                            <label class="fw-bold">¿Quién Reporta?<span
                                                    style="color: red">*</span></label>
                                            <input type="text" class="form-style mayusculas " name="NombreReporta"
                                                placeholder="Nombre" id="NombreReporta" required autocomplete="off" />
                                        </div>
                                        <div class="col-lg-2">
                                            <label class="fw-bold">Hora recogida</label>
                                            <input type="text" class="form-style mayusculas " name="HoraSalida"
                                                id="HoraSalida" />
                                        </div>
                                        <div class="col-lg-1">
                                            <label class="fw-bold">Ruta</label>
                                            <input type="text" class="form-style mayusculas " name="Ruta" id="Ruta" />
                                        </div>
                                    </div>
                                    <br>
                                    <div class="row" id="div_PagoAgencia">
                                        <div class="col-lg-2">
                                            <label class="fw-bold">Pago Agencia</label>
                                            <input type="text" class="form-style mayusculas " name="PagoAgencia"
                                                id="PagoAgencia" value="0">
                                        </div>
                                    </div>
                                    <br>
                                    <div class="row">
                                        <label class="fw-bold">Observaciones</label>
                                        <div class="form-floating">
                                            <textarea type="text" class="form-style mayusculas " name="Observaciones"
                                                style="height: 100px"></textarea></textarea>
                                        </div>
                                    </div>
                                    <br />
                                    <div class="input-group">
                                        <h3 class="mb-0">
                                            <strong>Datos de los pasajeros</strong> &nbsp;
                                        </h3>
                                    </div>
                                    <br />
                                    <div>
                                        <h3>Adultos</h3>
                                        <div id="div_adultos">
                                        </div>
                                        <br>
                                        <div class="">
                                            <button type="button" class="icon-btn add-btn plus" id="Agregar_Adulto">
                                                <div class="add-icon"></div>
                                                <div class="btn-txt">Agregar</div>
                                            </button>
                                        </div>
                                        <hr>
                                    </div>
                                    <div>
                                        <h3>Niños</h3>
                                        <div id="div_niños">
                                        </div>
                                        <br>
                                        <div class="">
                                            <button type="button" class="icon-btn add-btn plus" id="Agregar_Niños">
                                                <div class="add-icon"></div>
                                                <div class="btn-txt">Agregar</div>
                                            </button>
                                        </div>
                                        <hr>
                                    </div>
                                    <div>
                                        <h3>Infantes</h3>
                                        <div id="div_infantes">
                                        </div>
                                        <br>
                                        <div class="">
                                            <button type="button" class="icon-btn add-btn plus" id="Agregar_Infantes">
                                                <div class="add-icon"></div>
                                                <div class="btn-txt">Agregar</div>
                                            </button>
                                        </div>
                                        <hr>
                                    </div>

                                    <input type="button" name="Exportar" value="Guardar" class="btn-flotante"
                                        id="save-btn">

                                    <input type="submit" value="" id="Submit">
                        </form>

                    </div>
                </div>
                <div id="modal" class="modal" tabindex="-1" role="dialog" data-backdrop="static">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modal-header">
                                <h2>Puntos de encuentro</h2>
                            </div>
                            <div class="modal-body">
                                <div class="search-container">
                                    <input type="checkbox" id="checkbox_Punto_1" name="toggle"
                                        class="llegan-a-checkbox mx-sm-3 mb-2 sw"> <label
                                        for="checkbox_Punto_1"><span>LLEGAN A</span>
                                    </label>
                                    <input type="text" class="form-style" placeholder="Punto de encuentro principal"
                                        id="Punto_1" autocomplete="off">
                                    <div class="search">
                                        <span id="search_result_Punto_1"></span>
                                    </div>
                                </div>
                                <br>
                                <div class="search-container">
                                    <input type="checkbox" id="checkbox_Punto_2" name="toggle"
                                        class="llegan-a-checkbox mx-sm-3 mb-2 sw"> <label
                                        for="checkbox_Punto_2"><span>LLEGAN A</span>
                                    </label>
                                    <input type="text" class="form-style" placeholder="Punto de encuentro 2"
                                        id="Punto_2" autocomplete="off">
                                    <div class="search">
                                        <span id="search_result_Punto_2"></span>
                                    </div>
                                </div>
                                <br>
                                <div class="search-container">
                                    <input type="checkbox" id="checkbox_Punto_3" name="toggle"
                                        class="llegan-a-checkbox mx-sm-3 mb-2 sw"><label
                                        for="checkbox_Punto_3"><span>LLEGAN A</span>
                                    </label>
                                    <input type="text" class="form-style" placeholder="Punto de encuentro 3"
                                        id="Punto_3" autocomplete="off">
                                    <div class="search">
                                        <span id="search_result_Punto_3"></span>
                                    </div>
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="button" id="modal-btn-agregar">Listo</button>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="modalNP" class="modal" tabindex="-1" role="dialog" data-backdrop="static">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <div class="modalNP-header">
                                <h2>Nuevo punto de encuentro:</h2>
                            </div>
                            <div class="modal-body">
                                <div class="card-header">
                                    <input type="hidden" name="Id_PuntoNP" id="Id_PuntoNP">
                                    <span style="font-size:12px">Los campos con <span class="text-danger">*</span> son
                                        obligatorios.</span>
                                </div>
                                <div class="card-body">
                                    <div class="row">
                                        <div class="col-12">
                                            <label for="NombrePuntoNP" class="FormNewTour">Nombre<span
                                                    class="text-danger">*</span></label>
                                            <input type="text" name="NombrePuntoNP" id="NombrePuntoNP"
                                                class="form-style mayusculas " placeholder="Nombre del Punto"
                                                required="required">
                                        </div>


                                    </div>

                                </div>
                                <div class="modal-footer">
                                    <button type="button" id="modal-btn-NP" onclick="punto();">Crear</button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <% if(typeof alert !="undefined" ){ %>
        <script>
            swal({
                title: '<%= alertTitle %>',
                text: '<%= alertMessage %>',
                icon: '<%= alertIcon %>',
                showConfirmButton: '<%= showConfirmButton %>',
                timer: '<%= timer %>'
            }).then(() => {
                window.location = '/<%= ruta %>'
            })
        </script>
        <% } %>

            <script>

                const inputPrincipal = document.getElementById("NombrePunto");
                const modal = document.getElementById("modal");
