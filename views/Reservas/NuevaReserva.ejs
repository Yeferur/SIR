/*************  ✨ Codeium Command ⭐  *************/
/**
 * Closes the modal and updates the main input field with selected values.
 * Iterates over each input element in the modal to check if the associated
 * checkbox is checked and if the input has a value. If both conditions are met,
 * adds the prefix "LLEGAN A" to the input value and stores it. Otherwise, stores
 * the input value as-is if it is not empty. Joins all stored values into a single
 * string and sets it as the value of the main input field. Finally, hides the modal.
 */

/******  b3da0d7e-7d14-48e0-a1a0-1eaa4b7f798f  *******/
                function closeModal() {
                    let selectedInputs = [];

                    modalInputs.forEach((input) => {
                        const checkbox = document.getElementById(`checkbox_${input.id}`);
                        const inputValue = input.value.trim();

                        if (checkbox.checked && inputValue) {
                            selectedInputs.push(`LLEGAN A ${inputValue}`);
                        } else if (inputValue) {
                            selectedInputs.push(inputValue);
                        }
                    });

                    inputPrincipal.value = selectedInputs.join(", ");
                    modal.style.display = "none";
                }

                // Evento para abrir el modal al hacer focus en el input principal
                inputPrincipal.addEventListener("focus", openModal);

                // Evento para cerrar el modal al presionar el botón "Agregar" y actualizar el input principal
                modalBtnAgregar.addEventListener("click", closeModal);

                // Evento para cerrar el modal al presionar la tecla "Enter" y actualizar el input principal
                modal.addEventListener("keydown", (e) => {
                    if (e.key === "Enter") {
                        closeModal();
                    }
                });

                // Función para abrir el modal para crear un nuevo punto de encuentro
                function openModalNP() {
                    modalNP.style.display = "block";
                    if (modalInputs[0].value == "") {
                        modalInputs[0].focus();
                    }
                }

                // Función para cerrar el modal del nuevo punto
                function closeModalNP() {
                    let datos = [];
                    modalInputs.forEach((input) => {
                        datos.push(input.value.trim());
                    });
                    let filteredDatos = datos.filter((dato) => dato !== ""); // Elimina valores vacíos
                    if (filteredDatos.length > 1) {
                        inputPrincipal.value = filteredDatos.join(", ");
                    } else {
                        inputPrincipal.value = filteredDatos[0] || ""; // Asigna el primer valor o un string vacío si no hay valores
                    }
                    modalNP.style.display = "none";
                }


                // Evento para cerrar el modal al presionar el botón "Agregar" y actualizar el input principal
                modalBtnNP.addEventListener("click", closeModalNP);

