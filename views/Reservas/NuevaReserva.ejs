                function validate_autocomplete_input(input) {
                    return input.getAttribute('data-selected') === 'true';
                }

                function validate_inputs() {
                    var inputs = document.querySelectorAll('.search-container input[type="text"]');
                    var valid = true;

                    inputs.forEach(function (input) {
                        if (input.value && !validate_autocomplete_input(input)) {
                            valid = false;
                            swal("Error", "Por favor, seleccione un punto de encuentro válido para " + input.placeholder + ".", "warning");
