                    var telefonos = $('input[name="Telefono[]"]').map(function () {
                        return $(this).val();
                    }).get();

                    // Verifica si alguno de los campos de teléfono tiene un valor
                    var algunoConTelefono = telefonos.some(function (telefono) {
                        return telefono.trim() !== '';
                    });

                    if (!algunoConTelefono) {
                        return false; // Evita que el formulario se envíe
                    }

                    return true;
                }


