<!DOCTYPE html>
<html lang="es	">

<head>
    <title>Editar Reserva</title>
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <link rel="shortcut icon" href="../img/SIR.png" />
    <style>
        .form-styleCount {
            padding: 13px 20px;
            padding-left: 55px;
            margin-top: 5px;
            height: 48px;
            width: 100%;
            font-weight: 500;
            border-radius: 4px;
            font-size: 14px;
            line-height: 22px;
            letter-spacing: 0.5px;
            outline: none;
            color: #c4c3ca;
            background-color: #1f2029;
            border: none;
            -webkit-transition: all 200ms linear;
            transition: all 200ms linear;
            box-shadow: 0 4px 8px 0 rgba(21, 21, 21, .2);
        }

        .custom-btn {
            width: 60px;
            height: 40px;
            color: #fff;
            border-radius: 5px;
            padding: 10px 25px;
            font-family: 'Lato', sans-serif;
            font-weight: 500;
            background: transparent;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            display: inline-block;
            box-shadow: inset 2px 2px 2px 0px rgba(0, 0, 0, 0.5),
                7px 7px 20px 0px rgba(0, 0, 0, .1),
                4px 4px 5px 0px rgba(0, 0, 0, .1);
            outline: none;
        }

        .remove {
            background: rgb(240, 9, 9);
            background: linear-gradient(0deg, rgb(240, 9, 9) 0%, rgb(240, 5, 5) 100%);
            border: none;

        }

        .remove:before {
            height: 0%;
            width: 2px;
        }

        .remove:hover {
            box-shadow: 4px 4px 6px 0 rgb(45, 29, 29),
                -4px -4px 6px 0 rgb(45, 28, 28),
                inset -4px -4px 6px 0 rgba(255, 255, 255, .2),
                inset 4px 4px 6px 0 rgba(0, 0, 0, .4);
        }

        .btnn {
            background-color: #102770;
            color: #fff;
        }

        .icon-btn {
            width: 50px;
            height: 50px;
            border: 1px solid #1f2029;
            background: #1f2029;
            border-radius: 25px;
            overflow: hidden;
            position: relative;
            transition: width 0.2s ease-in-out;
            color: #fff;
        }

        .add-btn:hover {
            width: 120px;
        }

        .add-btn::before,
        .add-btn::after {
            transition: width 0.2s ease-in-out, border-radius 0.2s ease-in-out;
            content: "";
            position: absolute;
            height: 4px;
            width: 10px;
            top: calc(50% - 2px);
            background: red;
        }

        .plus::before,
        .plus::after {
            background: #66ff00;
        }

        .add-btn::after {
            right: 14px;
            overflow: hidden;
            border-top-right-radius: 2px;
            border-bottom-right-radius: 2px;
        }

        .add-btn::before {
            left: 14px;
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .icon-btn:focus {
            outline: none;
        }

        .btn-txt {
            opacity: 0;
            transition: opacity 0.2s;
            font-size: 13px;
        }

        .add-btn:hover::before,
        .add-btn:hover::after {
            width: 4px;
            border-radius: 2px;
        }

        .add-btn:hover .btn-txt {
            opacity: 1;
        }

        .add-icon::after,
        .add-icon::before {
            transition: all 0.2s ease-in-out;
            content: "";
            position: absolute;
            height: 20px;
            width: 2px;
            top: calc(50% - 10px);
            background: #66ff00;
            overflow: hidden;
        }

        .add-icon::before {
            left: 22px;
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .add-icon::after {
            right: 22px;
            border-top-right-radius: 2px;
            border-bottom-right-radius: 2px;
        }

        .add-btn:hover .add-icon::before {
            left: 15px;
            height: 4px;
            top: calc(50% - 2px);
        }

        .add-btn:hover .add-icon::after {
            right: 15px;
            height: 4px;
            top: calc(50% - 2px);
        }

        #search {
            top: 45px;
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        .search-container {
            position: relative;
        }

        .search-container .search {
            top: 70px;
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        #search::after {
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        .list-group-color {
            background: #1f2029;
            color: #fff;
        }

        .list-group-disabled-bg {
            background: #1f2029 !important;
            color: #fff !important;
        }

        .list-group-create-color {
            background: #1f2029;
            color: #45acdf;
        }

        .list-group-create-color:hover {
            background: #2a2f3a;
            color: #45acdf;
        }

        .list-group-color:hover,
        .list-group-disabled-color:hover {
            background: #2a2f3a;
            color: #fff;
        }


        /* Estilos para el modal */
        #modalP,
        #modalNP {
            display: none;
            position: fixed;
            z-index: 1;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            overflow: auto;
            background-color: rgba(0, 0, 0, 0.4);
        }

        .modal-content {
            background-color: #2a2f3a;
            margin: 15% auto;
            padding: 20px;
            border: none;
        }

        .modal-header h2 {
            margin-top: 0;
        }

        .modal-body input {
            display: block;
            margin-bottom: 10px;
            padding: 10px;
        }

        .modal-footer {
            text-align: right;
        }

        .modal-footer button {
            background-color: #4CAF50;
            color: white;
            border: none;
            padding: 10px 20px;
            border-radius: 4px;
            cursor: pointer;
        }

        .modal-footer button:hover {
            background-color: #45a049;
        }

        input.sw {
            opacity: 0;
            position: absolute;
            left: -9999px;
        }

        input.sw+label {
            -webkit-user-select: none;
            -moz-user-select: none;
            -ms-user-select: none;
            user-select: none;
            transition: 0.2s ease;
            display: inline-block;
            height: 22px;
            /* Tamaño reducido */
            width: 40px;
            /* Tamaño reducido */
            position: relative;
            box-shadow: inset 0 0 0px 2px #e4e4e4;
            border-radius: 30px;
            /* Radio reducido */
            /* White toggle */
        }

        input.sw+label:before {
            content: "";
            position: absolute;
            display: block;
            height: 22px;
            /* Tamaño reducido */
            width: 22px;
            /* Tamaño reducido */
            top: 0;
            left: 0;
            border-radius: 11px;
            /* Radio reducido */
            background: rgba(76, 217, 100, 0);
            transition: 0.2s cubic-bezier(0.24, 0, 0.5, 1);
        }

        input.sw+label:after {
            content: "";
            position: absolute;
            display: block;
            height: 20px;
            /* Tamaño reducido */
            width: 20px;
            /* Tamaño reducido */
            top: 50%;
            margin-top: -10px;
            /* Ajustado para centrar */
            left: 1px;
            border-radius: 50%;
            /* Radio reducido */
            background: #fff;
            box-shadow: 0 0 0 1px rgba(0, 0, 0, 0.1), 0 4px 0px 0 rgba(0, 0, 0, 0.04), 0 4px 9px rgba(0, 0, 0, 0.13), 0 3px 3px rgba(0, 0, 0, 0.05);
            transition: 0.35s cubic-bezier(0.54, 1.6, 0.5, 1);
        }

        input.sw+label span {
            white-space: nowrap;
            height: 22px;
            /* Tamaño reducido */
            line-height: 22px;
            /* Ajustado para el nuevo tamaño */
            margin-left: 40px;
            /* Tamaño reducido */
            padding-left: 12px;
            /* Ajustado para el nuevo tamaño */
        }

        input.sw:checked+label:before {
            width: 40px;
            /* Tamaño reducido */
            background: #4cd964;
            transition: width 0.2s cubic-bezier(0, 0, 0, 0.1) !important;
        }

        input.sw:checked+label:after {
            left: 18px;
            /* Ajustado para el nuevo tamaño */
        }

        input.sw:checked+label {
            box-shadow: inset 0 0 0px 25px #e4e4e4;
            transition: box-shadow 2.5s cubic-bezier(0, 1.2, 0.94, 0.95);
        }
    </style>
</head>

<body>
    <main class="content">

        <div class="container-fluid p-0">
            <div class="container">
                <% if (typeof Reserva !="undefined" ) { %>
                    <button class="back-button" onclick="window.location.href = '../../Reservas/VerReservas'">&larr;
                        Volver</button>
                    <div class="card">
                        <div class="card-header">
                            <div class="row">
                                <div class="col input-group">
                                    <h3 class="mb-0">
                                        <strong>Reserva: <%=Reserva.Id_Reserva %></strong> &nbsp;&nbsp;&nbsp;
                                    </h3>
                                </div>
                                <div class="col d-flex justify-content-end">
                                    <a type="button" class="delete" id="deleteReserva">
                                        Cancelar
                                    </a>
                                    <input type="hidden" name="" id="Id_Reserva" value="<%=Reserva.Id_Reserva %>">
                                </div>
                            </div>
                            <span style="font-size: 12px">Los campos con <span class="text-danger">*</span> son
                                obligatorios.</span>
                        </div>
                        <div class="card-body">
                            <form action="/EditReserva" method="POST" autocomplete="off">
                                <input type="hidden" name="Id_Reserva" id="Id_Reserva" value="<%=Reserva.Id_Reserva %>">
                                <% if (typeof user !="undefined" ){ %>
                                    <input type="hidden" name="id_user" id="id_user" value="<%=user.id_user %>">
                                    <% } %>
                                        <div class="row">
                                            <div class="col-3">
                                                <label class="fw-bold">Tipo de reserva</label>
                                                <select class="form-style" name="TipoReserva" id="TipoReserva"
                                                    onchange="callCupos();">
                                                    <option value="Grupal" selected>Grupal</option>
                                                    <option value="Privada">Privada</option>
                                                </select>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Estado de la reserva</label>
                                                <select class="form-style" name="Estado" id="Estado">
                                                    <option value="Activo">ACTIVO</option>
                                                    <option value="Pendiente">PENDIENTE</option>
                                                    <option value="Completado">COMPLETADO</option>
                                                    <option value="Cancelado">CANCELADO</option>
                                                </select>
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row">
                                            <div class="col-lg-3 ">
                                                <label class="fw-bold">Numero de Pasajeros:</label>
                                                <input class="form-style" type="text" name="" id="numpas"
                                                    value="<%=Reserva.NumeroPasajeros %>" disabled>
                                                <input type="hidden" name="NumeroPasajeros" id="NumeroPasajeros"
                                                    value="<%=Reserva.NumeroPasajeros %>">
                                                <input type="hidden" name="input_numpas" id="input_numpas"
                                                    value="<%=Reserva.NumeroPasajeros %>">
                                                <input type="hidden" name="TotalPasajeros" id="TotalPasajeros"
                                                    value="<%=Reserva.TotalPasajeros %>">
                                                <input type="hidden" name="total_pas" id="total_pas"
                                                    value="<%=Reserva.TotalPasajeros %>">
                                                <input type="hidden" name="NewPasajeros" id="NewPasajeros">
                                                <div class="section-dropdown" style="display: none;">
                                                    <div class="form-group">
                                                        <input type="text" name="adultos"
                                                            class="form-styleCount mayusculas " placeholder="Adultos"
                                                            id="adultos" onkeyup="numpas();" autocomplete="off">
                                                    </div>
                                                    <div class="form-group">
                                                        <input type="text" name="niños"
                                                            class="form-styleCount mayusculas " placeholder="Niños"
                                                            id="niños" onkeyup="numpas();" autocomplete="off">
                                                    </div>
                                                    <div class="form-group">
                                                        <input type="text" name="infantes"
                                                            class="form-styleCount mayusculas " placeholder="Infantes"
                                                            id="infantes" onkeyup="numpas();" autocomplete="off">
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Tour<span style="color: red">*</span></label>
                                                <select class="form-style mayusculas " name="SelectTour"
                                                    onchange="select_Tour();" id="SelectTour">
                                                    <% if (typeof resultsTours !="undefined" ){
                                                        resultsTours.forEach((Tours)=>{
                                                        %>
                                                        <option value="<%= Tours.Id_Tour %>">
                                                            <%= Tours.NombreTour %>
                                                        </option>
                                                        <% }) } %>
                                                </select>
                                                <input type="hidden" id="OriginalTour" value="<%=Reserva.TourReserva %>">
                                            </div>
                                            <div class="col-lg-3" id="punto">
                                                <label class="fw-bold">Puntos de encuentro<span
                                                        style="color: red">*</span></label>
                                                <div class="input-group mb-3">
                                                    <input type="text" class="form-style mayusculas " placeholder=""
                                                        id="NombrePunto" name="NombrePunto"
                                                        value="<%=Reserva.PuntoEncuentro %>">
                                                    <input type="hidden" id="Id_Punto" name="Id_Punto"
                                                        value="<%=Reserva.Id_Punto %>">
                                                </div>
                                            </div>

                                            <div class="col-lg-3">
                                                <label class="fw-bold">Fecha del tour<span
                                                        style="color: red">*</span></label>
                                                <input type="date" class="form-style mayusculas " name="FechaReserva"
                                                    value="<%=Reserva.FechaReserva %>" id="FechaReserva"
                                                    onchange="callCupos()" required />
                                                    <input type="hidden" name="" id="OriginalFecha" value="<%=Reserva.FechaReserva %>">
                                            </div>
                                        </div>
                                        <div class="row">
                                            <div class="col-lg-3">
                                                <label class="fw-bold"># Tel. Reserva<span
                                                        style="color: red">*</span></label>
                                                <input type="text" class="form-style mayusculas " name="TelefonoReserva"
                                                    id="TelefonoReserva" value="<%=Reserva.TelefonoReserva %>"
                                                    required />
                                            </div>
                                            <div class="col-lg-2">
                                                <label class="fw-bold">Idioma</label>
                                                <select class="form-style" name="IdiomaReserva" id="IdiomaReserva">
                                                    <option value="ESPAÑOL">ESPAÑOL</option>
                                                    <option value="INGLÉS">INGLÉS</option>
                                                </select>
                                            </div>
                                            <div class="col-lg-2">
                                                <label class="fw-bold">Categoría</label>
                                                <select class="selectpicker form-style" title="Seleccionar"
                                                    name="Categoria" id="Categoria" onchange="call_Load_Comision()">
                                                    <% if(typeof resultsCategoria !="undefined" ){
                                                        resultsCategoria.forEach((Categoria)=>{ %>
                                                        <option value="<%= Categoria.Id_Categoria %>">
                                                            <%= Categoria.Categoria %>
                                                        </option>
                                                        <% }) }%>
                                                </select>
                                            </div>
                                            <div class="col-lg-2">
                                                <label class="fw-bold">¿Quién Reporta?</label>
                                                <input type="text" class="form-style mayusculas " name="NombreReporta"
                                                    placeholder="Nombre" id="NombreReporta"
                                                    value="<%=Reserva.NombreReporta %>" />
                                            </div>
                                            <div class="col-lg-2">
                                                <label class="fw-bold">Hora recogida</label>
                                                <input type="text" class="form-style mayusculas " name="HoraSalida"
                                                    id="HoraSalida" value="<%=Reserva.HoraSalida %>" />
                                            </div>
                                            <div class="col-lg-1">
                                                <label class="fw-bold">Ruta</label>
                                                <input type="text" class="form-style mayusculas " name="Ruta" id="Ruta"
                                                    value="<%=Reserva.Ruta %>" />
                                            </div>
                                        </div>
                                        <br />
                                        <div class="row" id="div_PagoAgencia">
                                            <div class="col-lg-2">
                                                <label class="fw-bold">Pago Agencia</label>
                                                <input type="text" class="form-style mayusculas " name="PagoAgencia"
                                                    id="PagoAgencia" value="<%=Reserva.PagoAgencia %>">
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row">
                                            <label class="fw-bold">Observaciones</label>
                                            <div class="form-floating">
                                                <input type="text" class="form-style mayusculas "
                                                    value="<%=Reserva.Observaciones %>" name="Observaciones"
                                                    style="height: 100px">
                                            </div>
                                        </div>
                                        <br />
                                        <div class="input-group">
                                            <h3 class="mb-0">
                                                <strong>Datos de los pasajeros</strong> &nbsp;
                                            </h3>
                                        </div>
                                        <br />
                                        <div>
                                            <h3>Adultos</h3>
                                            <div id="div_adultos">
                                            </div>
                                            <br>
                                            <div class="">
                                                <button type="button" class="icon-btn add-btn plus"
                                                    onclick="callCupos()" id="Agregar_Adulto">
                                                    <div class="add-icon"></div>
                                                    <div class="btn-txt">Agregar</div>
                                                </button>
                                            </div>
                                            <hr>
                                        </div>
                                        <div>
                                            <h3>Niños</h3>
                                            <div id="div_niños">
                                            </div>
                                            <br>
                                            <div class="">
                                                <button type="button" class="icon-btn add-btn plus"
                                                    onclick="callCupos()" id="Agregar_Niños">
                                                    <div class="add-icon"></div>
                                                    <div class="btn-txt">Agregar</div>
                                                </button>
                                            </div>
                                            <hr>
                                        </div>
                                        <div>
                                            <h3>Infantes</h3>
                                            <div id="div_infantes">
                                            </div>
                                            <br>
                                            <div class="">
                                                <button type="button" class="icon-btn add-btn plus"
                                                    onclick="" id="Agregar_Infantes">
                                                    <div class="add-icon"></div>
                                                    <div class="btn-txt">Agregar</div>
                                                </button>
                                            </div>
                                            <hr>
                                        </div>
                                        <div class=" d-flex align-items-center justify-content-end ">
                                            <button type="button" class="btn btn-secondary btn-lg " id="duplica"
                                                data-bs-toggle="modal" data-bs-target="#ModalDuplicar">Duplicar</button>
                                            &nbsp;
                                            <button type="button" class="btn btn-primary btn-lg"
                                                id="save-btn">Guardar</button>
                                        </div>
                                        <input type="submit" value="" id="Submit">
                            </form>
                        </div>
                    </div>
                    <script type="text/javascript">
                        $(document).ready(function () {
                            $('#SelectTour').val('<%=Reserva.TourReserva %>');
                            $('#IdiomaReserva').val('<%=Reserva.IdiomaReserva %>');
                            $('#Categoria').val('<%=Reserva.CategoriaReserva %>');
                            $('#TipoReserva').val('<%=Reserva.TipoReserva %>');
                            $('#Estado').val('<%=Reserva.Estado %>');
                        });
                    </script>

                    <div id="modalP" class="modal" tabindex="-1" role="dialog" data-backdrop="static">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h2>Puntos de encuetro</h2>
                                </div>
                                <div class="modal-body">
                                    <div class="search-container">
                                        <input type="checkbox" id="checkbox_Punto_1" name="toggle"
                                            class="llegan-a-checkbox mx-sm-3 mb-2 sw" <% if (Reserva.PuntoEncuentro &&
                                            Reserva.PuntoEncuentro.split(',')[0] &&
                                            Reserva.PuntoEncuentro.split(',')[0].includes('LLEGAN A')) { %> checked <% }
                                            %>> <label for="checkbox_Punto_1"><span>LLEGAN A</span>
                                            </label>
                                            <input type="text" class="form-style"
                                                placeholder="Punto de encuentro principal"
                                                value="<%= Reserva.PuntoEncuentro && Reserva.PuntoEncuentro.split(',')[0] ? Reserva.PuntoEncuentro.split(',')[0].replace('LLEGAN A ', '') : '' %>"
                                                id="Punto_1" autocomplete="off">
                                            <div class="search">
                                                <span id="search_result_Punto_1"></span>
                                            </div>
                                    </div>
                                    <br>
                                    <div class="search-container">
                                        <input type="checkbox" id="checkbox_Punto_2" name="toggle"
                                            class="llegan-a-checkbox mx-sm-3 mb-2 sw" <% if (Reserva.PuntoEncuentro &&
                                            Reserva.PuntoEncuentro.split(',')[1] &&
                                            Reserva.PuntoEncuentro.split(',')[1].includes('LLEGAN A')) { %> checked <% }
                                            %>> <label for="checkbox_Punto_2"><span>LLEGAN A</span>
                                            </label>
                                            <input type="text" class="form-style" placeholder="Punto de encuentro 2"
                                                value="<%= Reserva.PuntoEncuentro && Reserva.PuntoEncuentro.split(', ')[1] ? Reserva.PuntoEncuentro.split(', ')[1].replace('LLEGAN A ', '') : '' %>"
                                                id="Punto_2" autocomplete="off">
                                            <div class="search">
                                                <span id="search_result_Punto_2"></span>
                                            </div>
                                    </div>
                                    <br>
                                    <div class="search-container">
                                        <input type="checkbox" id="checkbox_Punto_3" name="toggle"
                                            class="llegan-a-checkbox mx-sm-3 mb-2 sw" <% if (Reserva.PuntoEncuentro &&
                                            Reserva.PuntoEncuentro.split(',')[2] &&
                                            Reserva.PuntoEncuentro.split(',')[2].includes('LLEGAN A')) { %> checked <% }
                                            %>> <label for="checkbox_Punto_3"><span>LLEGAN A</span>
                                            </label>
                                            <input type="text" class="form-style" placeholder="Punto de encuentro 3"
                                                value="<%= Reserva.PuntoEncuentro && Reserva.PuntoEncuentro.split(', ')[2] ? Reserva.PuntoEncuentro.split(', ')[2].replace('LLEGAN A ', '') : '' %>"
                                                id="Punto_3" autocomplete="off">
                                            <div class="search">
                                                <span id="search_result_Punto_3"></span>
                                            </div>
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" id="modal-btn-agregar">Listo</button>
                                </div>
                            </div>
                        </div>
                    </div>


                    <div id="modalNP" class="modal" tabindex="-1" role="dialog" data-backdrop="static">
                        <div class="modal-dialog">
                            <div class="modal-content">
                                <div class="modalNP-header">
                                    <h2>Nuevo punto de encuentro:</h2>
                                </div>
                                <div class="modal-body">
                                    <div class="card-header">
                                        <input type="hidden" name="Id_PuntoNP" id="Id_PuntoNP">
                                        <span style="font-size:12px">Los campos con <span class="text-danger">*</span>
                                            son
                                            obligatorios.</span>
                                    </div>

                                    <div class="card-body">
                                        <div class="row">
