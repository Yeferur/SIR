                const inputs = document.querySelectorAll("input[id^='Punto']");
                const searchResults = document.querySelectorAll("span[id^='search_result_Punto']");

                inputs.forEach((input, index) => {
                    input.addEventListener("focus", () => {
                        const search = searchResults[index];
                        search.style.display = "block";
                    });

                    input.addEventListener("blur", () => {
                        const search = searchResults[index];
                        setTimeout(() => {
                            search.style.display = "none";
                        }, 200); // Agregamos un pequeño retardo para asegurarnos de que no se borre inmediatamente el spam
                    });
                });

                modalInputs.forEach((input) => {
                    input.addEventListener('keyup', () => {
                        const query = input.value.trim();
