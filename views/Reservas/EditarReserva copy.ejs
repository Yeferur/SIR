                function DeletePasajero(id) {
                    fetch('/DeletePasajero?id=' + id + '').then(function (response) {

                        return response.json();

                    }).then(function (responseData) {

                        if (responseData == 'error') {
                            swal({
                                title: "Ocurrió un error",
                                text: "No fue posible eliminar el pasajero, Si el error continúa, comuníquese con soporte técnico.",
                                icon: "error",

                            })
                        } else {
                            swal({
                                title: "¡Exito!",
                                text: "El pasajero se ha eliminado correctamente de la base de datos... (Recuerde que debe actualizar la reserva con el boton guardar para que tome los cambios)",
                                icon: "success",
                                buttons: true,
                            })
                            $('#' + responseData + '').remove();
                        }

                    });
                }

                async function cupos(Id_Tour, FechaReserva) {
                    try {
                        // Consultar la tabla 'aforos' para ver si hay cupos definidos para la fecha de reserva
                        const aforosResponse = await fetch(`/Reservas/Aforos?FechaReserva=${FechaReserva}&Id_Tour=${Id_Tour}`);
                        const resAforos = await aforosResponse.json();

                        let TotalCupos;
                        if (resAforos.length > 0) {
                            TotalCupos = resAforos[0].Cupos;
                        } else {
                            // Si no hay cupos definidos en 'aforos', consultar la tabla 'tours'
                            const tourResponse = await fetch(`/Cupos?Id_Tour=${Id_Tour}`);
                            const resCupos = await tourResponse.json();
                            TotalCupos = resCupos[0].Cupos;
                        }

                        // Validar si los cupos son suficientes
                        return await validarCupos(TotalCupos, Id_Tour, FechaReserva);
                    } catch (error) {
                        console.error("Error al validar los cupos:", error);
                        return false;
                    }
                }

                async function validarCupos(TotalCupos, Id_Tour, FechaReserva) {
                    try {
                        const NumeroPasajeros = parseInt($('#NumeroPasajeros').val() || 0, 10);
                        const input_numpas = parseInt($('#input_numpas').val() || 0, 10);
                        const totalPasajerosResponse = await fetch(`/TotalPasajeros?Id_Tour=${Id_Tour}&FechaReserva=${FechaReserva}`);
                        const TotalPasajeros = await totalPasajerosResponse.json();
                        
                        const Pasajeros = TotalPasajeros[0].Total || 0;
                        const TotalPas = Pasajeros + (input_numpas - NumeroPasajeros);

                        if (TotalPas > parseInt(TotalCupos)) {
                            swal({
                                title: "Error",
                                text: `No tenemos suficientes cupos para la fecha ${FechaReserva}... ¿Desea revisar los cupos disponibles? `,
                                icon: "error",
                                buttons: true,
                                dangerMode: true,
                            }).then((go) => {
                                if (go) {
                                    window.open("/", "_blank");
                                }
                            });
                            return false; // No hay cupos
                        }
                        return true; // Hay cupos disponibles
                    } catch (error) {
                        console.error("Error al validar el total de pasajeros:", error);
                        return false;
                    }
                }


