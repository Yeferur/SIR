                load_data = (query = '', Id_Tour, idInput) => {
                    fetch('/autocompletar?search_query=' + query + '&Id_Tour=' + Id_Tour + '').then(function (response) {

                        return response.json();

                    }).then(function (responseData) {

                        var html = '<ul class="list-group">';

                        if (responseData.length > 0) {
                            for (var count = 0; count < responseData.length; count++) {
                                var regular_expression = new RegExp('(' + query + ')', 'gi');

                                html += '<a class="list-group-item list-group-item-action list-group-color" onclick="get_text(this, \'' + idInput + '\'); call_Load_HR()">' + responseData[count].NombrePunto.replace(regular_expression, '<span class="text-primary fw-bold">$1</span>') + '</a>';
