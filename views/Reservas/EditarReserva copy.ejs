                    const mostrarAlerta = (mensaje, titulo = "Cuidado", icono = "warning") => {
                        return swal({
                            title: titulo,
                            text: mensaje,
                            icon: icono,
                            buttons: true,
                            dangerMode: true,
                        });
                    };

                    let textoAlerta = "";
                    const estadoReserva = $("#Estado").val();
                    const idReserva = $("#Id_Reserva").val();
                    const newTour = $("#SelectTour").val();
                    const newFecha = $("#FechaReserva").val();
                    const newPasajeros = parseInt($("#input_numpas").val() || 0, 10);

