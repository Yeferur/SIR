                function obtenerDatosduplicarReserva() {
                    // Obtener los valores del modal
                    var Id_ReservaDuplicar = document.getElementById("Id_ReservaDuplicar").value;
                    var Id_Tour = document.getElementById('SelectTourd').value;
                    var Id_Tourd = document.getElementById('SelectTourd').value;
                    var FechaReserva = document.getElementById('FechaReserva').value;
                    var FechaReservad = document.getElementById('FechaReservad').value;
                    var Observaciones = document.getElementById('Observacionesd').value;
                    var Estado = document.getElementById('Estadod').value;
                    // Obtener valores importantes del formulario principal
                    var TipoReserva = document.getElementById('TipoReserva').value;
                    var input_numpas = document.getElementById('input_numpas').value;
                    var total_pas = document.getElementById('total_pas').value;
                    var PuntoEncuentro = document.getElementById('NombrePunto').value;
                    var Id_Punto = document.getElementById('Id_Punto').value;
                    var TelefonoReserva = document.getElementById('TelefonoReserva').value;
                    var IdiomaReserva = document.getElementById('IdiomaReserva').value;
                    var Categoria = document.getElementById('Categoria').value;
                    var NombreReporta = document.getElementById('NombreReporta').value;
                    var id_user = document.getElementById('id_user').value;
                    var NomPas = [];
                    var TipoPasajero = [];
                    var IdPas = [];
                    var Telefono = [];

                    var nombreInputs = document.getElementsByName('NomPas[]');
                    var tipoPasajeroInputs = document.getElementsByName('tipo[]');
                    var idPasInputs = document.getElementsByName('IdPas[]');
                    var telefonoInputs = document.getElementsByName('Telefono[]');

                    for (var i = 0; i < nombreInputs.length; i++) {
                        NomPas.push(nombreInputs[i].value);
                        TipoPasajero.push(tipoPasajeroInputs[i].value);
                        IdPas.push(idPasInputs[i].value);
                        Telefono.push(telefonoInputs[i].value);
                    }

                    // Serializa los arrays en cadenas JSON
                    var nomPasJSON = JSON.stringify(NomPas);
                    var tipoPasajeroJSON = JSON.stringify(TipoPasajero);
                    var idPasJSON = JSON.stringify(IdPas);
                    var telefonoJSON = JSON.stringify(Telefono);

                    if (FechaReserva == FechaReservad) {
                        swal({
                            alert: true,
                            title: "¡Error!",
                            text: "La fecha de la nueva reserva debe ser diferente a la fecha de la reserva actual.",
                            icon: "error",
                            showConfirmButton: false,
                            timer: 3500,
                        });
                    } else {
                        cuposDuplicar = (Id_Tour, FechaReservad) => {
                            fetch('/Reservas/Aforos?FechaReserva=' + FechaReservad + '&Id_Tour=' + Id_Tour)
                                .then((aforosResponse) => {
                                    return aforosResponse.json();
                                })
                                .then((resAforos) => {
                                    if (resAforos.length > 0) {
                                        var TotalCupos = resAforos[0].Cupos;
                                        validarCuposDuplicar(TotalCupos);
                                    } else {
                                        fetch('/Cupos?Id_Tour=' + Id_Tour)
                                            .then((tourResponse) => {
                                                return tourResponse.json();
                                            })
                                            .then((resCupos) => {
                                                var TotalCupos = resCupos[0].Cupos;
                                                validarCuposDuplicar(TotalCupos);
                                            });
                                    }
                                });

                            function validarCuposDuplicar(TotalCupos) {
                                var NumPas = $('#input_numpas').val();
                                fetch('/TotalPasajeros?Id_Tour=' + Id_Tour + '&FechaReserva=' + FechaReservad)
                                    .then((res) => {
                                        return res.json();
                                    })
                                    .then((TotalPasajeros) => {
                                        var Pasajeros = TotalPasajeros[0].Total || 0;
                                        var TotalPas = Pasajeros + parseInt(NumPas);

                                        if (TotalPas > TotalCupos) {
                                            $("#save-btn").attr("disabled", true);
                                            swal({
                                                title: "Error",
                                                text: "No tenemos suficientes cupos para la fecha " + FechaReservad + "... ¿Desea revisar los cupos disponibles? ",
                                                icon: "error",
                                                buttons: true,
                                                dangerMode: true,
                                            }).then((go) => {
                                                if (go) {
                                                    window.location = "/";
                                                }
                                            });
                                        } else {
                                            fetch(`/Edit/DuplucarReserva`, {
                                                method: 'POST',
                                                headers: {
                                                    'Content-Type': 'application/json'
                                                },
                                                body: JSON.stringify({
                                                    Id_ReservaDuplicar,
                                                    TipoReserva,
                                                    input_numpas,
                                                    total_pas,
                                                    Id_Tour: Id_Tourd,
                                                    PuntoEncuentro,
                                                    Id_Punto,
                                                    FechaReserva: FechaReservad,
                                                    Observaciones,
                                                    TelefonoReserva,
                                                    IdiomaReserva,
                                                    Categoria,
                                                    NombreReporta,
                                                    Estado: Estado,
                                                    NomPas: nomPasJSON,
                                                    TipoPasajero: tipoPasajeroJSON,
                                                    IdPas: idPasJSON,
                                                    Telefono: telefonoJSON,
                                                    id_user: id_user
                                                })
                                            })
                                                .then((response) => {
                                                    return response.json();
                                                })
                                                .then((result) => {
                                                    if (result != null) {
                                                        swal({
                                                            alert: true,
                                                            title: "¡Ocurrió un error!",
                                                            text: "No fue posible duplicar la reserva. Si el error continúa, comuníquese con soporte técnico.",
                                                            icon: "error",
                                                            showConfirmButton: false,
                                                            timer: 3500,
                                                        });
                                                    } else {
                                                        swal({
                                                            alert: true,
                                                            title: "Exito",
                                                            text: "La reserva " + Id_ReservaDuplicar + " se ha creado correctamente. Será dirigido a la reserva para que complete los datos",
                                                            icon: "success",
                                                            timer: 2500,
                                                        }).then(() => {
                                                            window.location.replace("/Reservas/ReservaDuplicada/" + Id_ReservaDuplicar);
                                                        });
                                                    }
                                                })
                                                .catch((error) => {
                                                    swal({
                                                        alert: true,
                                                        title: "¡Ocurrió un error!",
                                                        text: "No fue posible duplicar la reserva. Si el error continúa, comuníquese con soporte técnico.",
                                                        icon: "error",
                                                        showConfirmButton: false,
                                                        timer: 3500,
                                                    });
                                                });
                                            $("#save-btn").removeAttr("disabled");
                                        }
                                    });
                            }
                        };

                        if (Id_Tour === "1") {
                            Id_Tour = 5;
                        }

                        if (Id_Tour !== 'Seleccionar' && FechaReservad !== '') {
                            try {
                                cuposDuplicar(Id_Tour, FechaReservad);
                            } catch (error) {
                                console.error('Error al llamar a la función cupos:', error);
                            }
                        }
                    }
