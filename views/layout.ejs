    <%-body%>

        <!--========== MAIN JS ==========-->
        <script>
            /*==================== SHOW NAVBAR ====================*/
            const showMenu = (headerToggle, navbarId) => {
                const toggleBtn = document.getElementById(headerToggle),
                    nav = document.getElementById(navbarId)

                // Validate that variables exist
                if (headerToggle && navbarId) {
                    toggleBtn.addEventListener('click', () => {
                        // We add the show-menu class to the div tag with the nav__menu class
                        nav.classList.toggle('show-menu')
                        // change icon
                        toggleBtn.classList.toggle('bx-x')
                    })
                }
            }
            showMenu('header-toggle', 'navbar')

            /*==================== LINK ACTIVE ====================*/
            const linkColor = document.querySelectorAll('.nav__link')

            function colorLink() {
                linkColor.forEach(l => l.classList.remove('active'))
                this.classList.add('active')
            }

            linkColor.forEach(l => l.addEventListener('click', colorLink))

            // Define una función para convertir el valor a mayúsculas
            function convertirAMayusculas() {
                const inputs = document.querySelectorAll(".form-style.mayusculas");

                inputs.forEach(input => {
                    input.value = input.value.toUpperCase();
                });
            }

            // Asocia la función con el evento input para cada campo
            document.addEventListener("input", function (event) {
                const targetElement = event.target;

                // Verifica si el elemento de destino tiene la clase y es un campo de entrada
                if (targetElement.classList.contains("form-style") && targetElement.classList.contains("mayusculas") && (targetElement.tagName === "INPUT" || targetElement.tagName === "TEXTAREA")) {
                    // Llama a la función para convertir a mayúsculas
                    convertirAMayusculas();
                }
            });

        </script>
