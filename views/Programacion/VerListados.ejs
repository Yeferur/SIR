<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Listado</title>
    <script src="https://unpkg.com/sweetalert/dist/sweetalert.min.js"></script>
    <style>
        .btn-flotante {
            font-size: 16px;
            /* Cambiar el tamaño de la tipografia */
            text-transform: uppercase;
            /* Texto en mayusculas */
            font-weight: bold;
            /* Fuente en negrita o bold */
            color: #ffffff;
            /* Color del texto */
            border-radius: 5px;
            /* Borde del boton */
            letter-spacing: 2px;
            /* Espacio entre letras */
            background-color: #be1919;
            /* Color de fondo */
            padding: 18px 30px;
            /* Relleno del boton */
            position: fixed;
            bottom: 40px;
            right: 40px;
            transition: all 300ms ease 0ms;
            box-shadow: 0px 8px 15px rgba(0, 0, 0, 0.1);
            z-index: 99;
        }

        .btn-flotante:hover {
            background-color: #2c2fa5;
            /* Color de fondo al pasar el cursor */
            box-shadow: 0px 15px 20px rgba(0, 0, 0, 0.3);
            transform: translateY(-7px);
        }



        @media only screen and (max-width: 600px) {
            .btn-flotante {
                font-size: 14px;
                padding: 12px 20px;
                bottom: 20px;
                right: 20px;
            }
        }
    </style>
</head>

<body>
    <main class="content">
        <div class="container container-fluid ">
            <div class="card">
                <div class="card-header">
                    <div class="input-group">
                        <h3 class="mb-0"><strong>LISTADOS</strong></h3>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-12">
                            <div class="form-group mx-sm-3 mb-2">
                                <label for="">Fecha del tour</label>
                                <input type="date" name="fecha" id="fecha" class="form-style mayusculas ">
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-group mx-sm-3 mb-6">
                                <label for="form-label">Tour</label>
                                <select name="" class="form-style mayusculas Select" id="select">
                                    <option value="" selected disabled>SELECCIONAR</option>
                                    <% if (typeof resultsTours !="undefined" ){ resultsTours.forEach((Tours)=>{
                                        %>
                                        <option value="<%= Tours.Id_Tour %>">
                                            <%= Tours.NombreTour %>
                                        </option>
                                        <% }) } %>
                                </select>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="form-group mx-sm-3 mb-6">
                                <label for="form-label">Ruta</label>
                                <select name="ruta[]" class="form-style mayusculas Select" id="ruta">
                                    <option value="" selected disabled>SELECCIONAR</option>
                                    <% if (typeof resultRutas !="undefined" ){ resultRutas.forEach((Rutas)=>{
                                        %>
                                        <option value="<%= Rutas.Ruta %>">
                                            <%= Rutas.Ruta %>
                                        </option>
                                        <% }) } %>
                                </select>
                            </div>
                        </div>
                        <div class="col-4" id="div_Info"></div>
                    </div>
                    <br>
                    <div class="row">
                        <div class="col-md-12">
                            <div class="form-group mx-sm-3 mb-2">
                                <button type="button" class="btn btn-primary btn-sm " id="filtrar">Filtrar</button>
                            </div>
                            <br><br>
                        </div>
                    </div>
                    <br>
                    <div class="row" id="div_Table">
                        <div class="d-flex align-items-center justify-content-center" id="div_Text">
                            <p>Seleccione una fecha y/o un tour para filtrar</p>
                        </div>
                    </div>
                    <br><br><br><br>
                </div>
            </div>
        </div>
    </main>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.17.4/xlsx.full.min.js"></script>


    <% if(typeof alert !="undefined" ){ %>
        <script>
            swal({
                title: '<%= alertTitle %>',
                text: '<%= alertMessage %>',
                icon: '<%= alertIcon %>',
                showConfirmButton: '<%= showConfirmButton %>',
                timer: '<%= timer %>'
            }).then(() => {
                window.location = '/<%= ruta %>'
            })
        </script>
        <% } %>


            <script>

                $("#save-btn").click(() => {
                    swal({
                        title: "¿Todo Listo?",
                        icon: "warning",
                        buttons: true,
                        dangerMode: true,
                    })
                        .then((go) => {
                            if (go) {
                                var placaBus = $("#placaBus").val();
                                if (placaBus == "") {
                                    swal({
                                        text: "Por favor ingrese la placa del bus.",
                                        icon: "warning",
                                    })
                                } else {
                                    guardarAsignacionBus(placaBus);
                                    console.log(placaBus);
                                }


                            }
                        });
                })

                let capacidadAutobus;
                $("#filtrar").click(function () {
                    var Fecha = $("#fecha").val();
                    var Tour = $("#select").val();
                    if (Tour === '1' || Tour === '5') {
                        Tour = ['1', '5'];
                    }
                    var Ruta = $("#ruta").val();
                    if ((Tour != '') || (Fecha != '') || (Ruta != '')) {
                        ObtenerDatos(Fecha, Tour, Ruta);
                    }
                })

                async function ObtenerDatos(fecha, tour, ruta) {
                    try {
                        const response = await fetch(`/VerListados/Tabla?fecha=${fecha}&tour=${tour}&ruta=${ruta}`);
                        const datos = await response.json();
                        Tabla(datos);
                    } catch (error) {
                        console.error("Error al buscar los datos filtrados:", error);
                    }
                }

                function Tabla(datos) {
                    let tabla = ''; // Variable para construir la tabla

                    if (datos.length > 0) {
                        tabla += '<div class="col-lg-12 table-responsive">';
                        tabla += '<table class="table table-striped table-hover table-bordered table-dark" id="Listado">';
                        tabla += '<thead>';
                        tabla += '<tr>';
                        tabla += '<th>Placa Bus</th>';
                        tabla += '<th>Guia</th>';
                        tabla += '<th>Capacidad Bus</th>';
                        tabla += '<th>Asientos Disponibles</th>';
                        tabla += '<th>Tour</th>';
                        tabla += '<th>Fecha</th>';
                        tabla += '<th>Acciones</th>';
                        tabla += '</tr>';
                        tabla += '</thead>';
                        tabla += '<tbody>';

                        datos.forEach(dato => {
                            tabla += '<tr>';
                            tabla += `<td>${dato.PlacaBus}</td>`;
                            tabla += `<td>${dato.Guia}</td>`;
                            tabla += `<td>${dato.CapacidadBus}</td>`;
                            tabla += `<td>${dato.AsientosDisponibles}</td>`;
                            tabla += `<td>${dato.Tour}</td>`;
                            tabla += `<td>${dato.Fecha}</td>`;
                            tabla += `<td><button onclick="editar(${dato.Id})">Editar</button>`;
                            tabla += `<button onclick="descargarExcel(${dato.Id})">Descargar Excel</button></td>`;
                            tabla += '</tr>';
                        });

                        tabla += '</tbody>';
                        tabla += '</table>';
                        tabla += '<br>';
                        tabla += '</div>';
                    } else {
                        tabla += '<div class="d-flex align-items-center justify-content-center" id="div_Text">';
                        tabla += '<p>No se encontraron datos.</p>';
                        tabla += '</div>';
                    }

                    // Insertar la tabla en el contenedor deseado
                    $("#div_Table").html(tabla);
                }


                $(document).ready(function () {
                    $("form").keypress(function (e) {
                        if (e.which == 13) {
                            return false;
                        }
                    });
                });
            </script>

</body>

</html>