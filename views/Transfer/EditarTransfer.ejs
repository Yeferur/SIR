<!DOCTYPE html>
<html lang="es">

<head>
    <title>Editar Transfer</title>
    <link rel="shortcut icon" href="../img/icons/icon.png" />
    <script src="https://code.jquery.com/jquery-3.5.1.min.js"></script>
    <link rel="stylesheet" href="../../resources/css/layout.css">
    <link rel="shortcut icon" href="../../resources/img/SIR.png" />
    <style>
        #dropdown:checked,
        #dropdown:not(:checked) {
            position: absolute;
            left: -9999px;
            opacity: 0;
            pointer-events: none;
        }

        .dropdown:checked+label,
        .dropdown:not(:checked)+label {
            position: relative;
            font-weight: 500;
            font-size: 15px;
            line-height: 2;
            height: 40px;
            transition: all 200ms linear;
            border-radius: 4px;
            width: 100%;
            letter-spacing: 1px;
            display: -webkit-inline-flex;
            display: -ms-inline-flexbox;
            display: inline-flex;
            -webkit-align-items: center;
            -moz-align-items: center;
            -ms-align-items: center;
            align-items: center;
            -webkit-justify-content: center;
            -moz-justify-content: center;
            -ms-justify-content: center;
            justify-content: center;
            -ms-flex-pack: center;
            text-align: center;
            border: none;
            background-color: #1f2029;
            cursor: pointer;
            color: #c4c3ca;
        }

        .section-dropdown {
            position: absolute;
            padding: 5px;
            background-color: #111;
            margin: 10px;
            left: 0;
            max-width: 300px;
            border-radius: 4px;
            display: block;
            box-shadow: 0 14px 35px 0 rgba(9, 9, 12, 0.4);
            z-index: 2;
            opacity: 0;
            pointer-events: none;
            transform: translateY(20px);
            transition: all 200ms linear;
        }

        .dark-light:checked~.sec-center .section-dropdown {
            background-color: #fff;
            box-shadow: 0 14px 35px 0 rgba(9, 9, 12, 0.15);
        }

        .dropdown:checked~.section-dropdown {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
        }

        .section-dropdown:before {
            position: absolute;
            top: -20px;
            left: 0;
            width: 100%;
            height: 20px;
            content: '';
            display: block;
            z-index: 1;
        }

        .section-dropdown:after {
            position: absolute;
            top: -7px;
            left: 30px;
            width: 0;
            height: 0;
            border-left: 8px solid transparent;
            border-right: 8px solid transparent;
            border-bottom: 8px solid #111;
            content: '';
            display: block;
            z-index: 2;
            transition: all 200ms linear;
        }



        .form-styleCount {
            padding: 13px 20px;
            padding-left: 55px;
            margin-top: 5px;
            height: 48px;
            width: 100%;
            font-weight: 500;
            border-radius: 4px;
            font-size: 14px;
            line-height: 22px;
            letter-spacing: 0.5px;
            outline: none;
            color: #c4c3ca;
            background-color: #1f2029;
            border: none;
            -webkit-transition: all 200ms linear;
            transition: all 200ms linear;
            box-shadow: 0 4px 8px 0 rgba(21, 21, 21, .2);
        }

        .custom-btn {
            width: 60px;
            height: 40px;
            color: #fff;
            border-radius: 5px;
            padding: 10px 25px;
            font-family: 'Lato', sans-serif;
            font-weight: 500;
            background: transparent;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            display: inline-block;
            box-shadow: inset 2px 2px 2px 0px rgba(0, 0, 0, 0.5),
                7px 7px 20px 0px rgba(0, 0, 0, .1),
                4px 4px 5px 0px rgba(0, 0, 0, .1);
            outline: none;
        }

        .remove {
            background: rgb(240, 9, 9);
            background: linear-gradient(0deg, rgb(240, 9, 9) 0%, rgb(240, 5, 5) 100%);
            border: none;

        }

        .remove:before {
            height: 0%;
            width: 2px;
        }

        .remove:hover {
            box-shadow: 4px 4px 6px 0 rgb(45, 29, 29),
                -4px -4px 6px 0 rgb(45, 28, 28),
                inset -4px -4px 6px 0 rgba(255, 255, 255, .2),
                inset 4px 4px 6px 0 rgba(0, 0, 0, .4);
        }

        .btnn {
            background-color: #102770;
            color: #fff;
        }

        .icon-btn {
            width: 50px;
            height: 50px;
            border: 1px solid #1f2029;
            background: #1f2029;
            border-radius: 25px;
            overflow: hidden;
            position: relative;
            transition: width 0.2s ease-in-out;
            color: #fff;
        }

        .add-btn:hover {
            width: 120px;
        }

        .add-btn::before,
        .add-btn::after {
            transition: width 0.2s ease-in-out, border-radius 0.2s ease-in-out;
            content: "";
            position: absolute;
            height: 4px;
            width: 10px;
            top: calc(50% - 2px);
            background: red;
        }

        .plus::before,
        .plus::after {
            background: #66ff00;
        }

        .add-btn::after {
            right: 14px;
            overflow: hidden;
            border-top-right-radius: 2px;
            border-bottom-right-radius: 2px;
        }

        .add-btn::before {
            left: 14px;
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .icon-btn:focus {
            outline: none;
        }

        .btn-txt {
            opacity: 0;
            transition: opacity 0.2s;
            font-size: 13px;
        }

        .add-btn:hover::before,
        .add-btn:hover::after {
            width: 4px;
            border-radius: 2px;
        }

        .add-btn:hover .btn-txt {
            opacity: 1;
        }

        .add-icon::after,
        .add-icon::before {
            transition: all 0.2s ease-in-out;
            content: "";
            position: absolute;
            height: 20px;
            width: 2px;
            top: calc(50% - 10px);
            background: #66ff00;
            overflow: hidden;
        }

        .add-icon::before {
            left: 22px;
            border-top-left-radius: 2px;
            border-bottom-left-radius: 2px;
        }

        .add-icon::after {
            right: 22px;
            border-top-right-radius: 2px;
            border-bottom-right-radius: 2px;
        }

        .add-btn:hover .add-icon::before {
            left: 15px;
            height: 4px;
            top: calc(50% - 2px);
        }

        .add-btn:hover .add-icon::after {
            right: 15px;
            height: 4px;
            top: calc(50% - 2px);
        }

        #search {
            top: 45px;
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        #search::before {
            display: block;
            position: absolute;
            z-index: 1 !important;
        }

        #search::after {
            display: block;
            position: absolute;
            z-index: 2 !important;
        }

        .list-group-color {
            background: #1f2029;
            color: #fff;
        }

        .list-group-disabled-bg {
            background: #1f2029 !important;
            color: #fff !important;
        }

        .list-group-create-color {
            background: #1f2029;
            color: #45acdf;
        }

        .list-group-create-color:hover {
            background: #2a2f3a;
            color: #45acdf;
        }

        .list-group-color:hover,
        .list-group-disabled-color:hover {
            background: #2a2f3a;
            color: #fff;
        }
    </style>
</head>

<body>

    <% if (typeof Transfer !="undefined" ) { %>
        <main class="content">

            <div class="container-fluid p-0">
                <div class="container">
                    <button class="back-button" onclick="window.location.href = '../../Transfer/VerTransfer'">&larr;
                        Volver</button>
                    <div class="card">
                        <div class="card-header">
                            <div class="row">
                                <div class="col input-group">
                                    <h3 class="mb-0">
                                        <strong>Transfer: <%= Transfer.Id_Transfer %> </strong> &nbsp;&nbsp;&nbsp;
                                    </h3>
                                </div>
                                <div class="col d-flex justify-content-end">
                                    <a type="button" class="delete" id="deleteTransfer">
                                        <iconify-icon icon="material-symbols:delete-outline" style="color: white;"
                                            width="30" height="30"></iconify-icon>
                                    </a>
                                    <input type="hidden" name="" id="Id_Transfer" value="<%= Transfer.Id_Transfer %>">
                                </div>
                            </div>
                            <span style="font-size: 12px">Los campos con <span class="text-danger">*</span> son
                                obligatorios.</span>
                        </div>
                        <div class="card-body">
                            <form action="/EditarTransfer" method="POST" autocomplete="off">
                                <input type="hidden" name="Id_Transfer" id="Id_Transfer"
                                    value="<%= Transfer.Id_Transfer %>">
                                <% if (typeof user !="undefined" ){ %>
                                    <input type="hidden" name="id_user" id="id_user" value="<%=user.id_user %>">
                                    <% } %>
                                        <div class="row">
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Estado del transfer</label>
                                                <select class="form-style" name="Estado" id="Estado">
                                                    <option value="Activo">ACTIVO</option>
                                                    <option value="Pendiente">PENDIENTE</option>
                                                    <option value="Cancelado">CANCELADO</option>
                                                    <option value="Completado">COMPLETADO</option>
                                                </select>
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row">
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Titular del servicio<span
                                                    style="color: red">*</span></label>
                                                <div class="input-group mb-3">
                                                    <input type="text" name="Titular" class="form-style mayusculas"
                                                        value="<%= Transfer.Titular %>" id="Titular">
                                                </div>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Número de contacto</label>
                                                <div class="input-group mb-3">
                                                    <input type="text" name="Tel_Contacto" class="form-style mayusculas"
                                                        value="<%= Transfer.Tel_Contacto %>">
                                                </div>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Número de Pasajeros<span
                                                    style="color: red">*</span></label>
                                                <input type="text" name="NumPas" class="form-style mayusculas "
                                                    placeholder="Número de pasajeros" id="NumPas"
                                                    value="<%= Transfer.NumeroPasajeros %>" autocomplete="off">
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Tipo de servicio<span
                                                    style="color: red">*</span></label>
                                                <select name="Servicio" id="Servicio" class="form-style mayusculas ">
                                                    <% if (typeof resultsServicio !="undefined" ){
                                                        resultsServicio.forEach((Servicio)=>{
                                                        %>
                                                        <option value="<%= Servicio.id %>">
                                                            <%= Servicio.Servicio %>
                                                        </option>
                                                        <% }) } %>
                                                </select>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Punto de salida</label>
                                                <div class="input-group mb-3">
                                                    <input type="text" name="Salida" class="form-style mayusculas "
                                                        value="<%= Transfer.Salida %>">
                                                </div>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Punto de llegada</label>
                                                <div class="input-group mb-3">
                                                    <input type="text" name="Llegada" class="form-style mayusculas "
                                                        value="<%= Transfer.Llegada %>">
                                                </div>
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Elige la fecha<span
                                                        style="color: red">*</span></label>
                                                <input type="date" class="form-style mayusculas " name="FechaTransfer"
                                                    id="FechaTransfer" value="<%= Transfer.FechaTransfer %>" required />
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">¿Quién Reporta?<span
                                                    style="color: red">*</span></label>
                                                <input type="text" class="form-style mayusculas " name="NombreReporta"
                                                    placeholder="Nombre" value="<%= Transfer.NombreReporta %>" id="NombreReporta"/>
                                            </div>
                                        </div>
                                        <div class="row">

                                            <div class="col-lg-3">
                                                <label class="fw-bold">Hora recogida</label>
                                                <input type="text" class="form-style mayusculas " name="HoraRecogida"
                                                    id="HoraSalida" value="<%= Transfer.HoraRecogida %>" />
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold"># Vuelo</label>
                                                <input type="text" class="form-style mayusculas " name="Vuelo"
                                                    id="Vuelo" value="<%= Transfer.Vuelo %>" />
                                            </div>


                                            <div class="col-lg-3">
                                                <label class="fw-bold"># Tel. Reserva<span
                                                        style="color: red">*</span></label>
                                                <input type="text" class="form-style mayusculas "
                                                    name="TelefonoTransfer" id="TelefonoTransfer"
                                                    value="<%= Transfer.TelefonoTransfer %>" required
                                                    autocomplete="off" />
                                            </div>
                                            <div class="col-lg-3">
                                                <label class="fw-bold">Valor del servicio</label>
                                                <input type="text" class="form-style mayusculas " name="ValorServicio"
                                                    value="<%= Transfer.ValorServicio %>" />
                                            </div>
                                        </div>
                                        <br>
                                        <div class="row">
                                            <label class="fw-bold">Observaciones</label>
                                            <div class="form-floating">
                                                <input type="text" class="form-style mayusculas "
                                                    value="<%=Transfer.Observaciones %>" name="Observaciones"
                                                    style="height: 100px">
                                            </div>
                                        </div>
                                        <br />
                                        <div class=" d-flex align-items-center justify-content-end ">
                                            <button type="button" class="btn btn-primary btn-lg"
                                                id="save-btn">Guardar</button>
                                        </div>
                                        <input type="submit" value="" id="Submit">
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </main>
        <script type="text/javascript">
            $(document).ready(function () {
                $('#Servicio').val('<%=Transfer.Servicio %>');
                $('#Estado').val('<%=Transfer.Estado %>');
            });

        </script>
        <% } %>

            <% if(typeof alert !="undefined" ){ %>
                <script>
                    swal({
                        title: '<%= alertTitle %>',
                        text: '<%= alertMessage %>',
                        icon: '<%= alertIcon %>',
                        showConfirmButton: '<%= showConfirmButton %>',
                        timer: '<%= timer %>'
                    }).then(() => {
                        window.location = '/<%= ruta %>'
                    })
                </script>
                <% } %>

                    <script>
                        $("#deleteTransfer").click(() => {
                            const Id_Transfer = $("#Id_Transfer").val();
                            const id_user = $("#id_user").val();
                            swal({
                                title: `¿Seguro desea cancelar el Transfer ${Id_Transfer}?`,
                                icon: "warning",
                                buttons: true,
                                dangerMode: true,
                            }).then((go) => {
                                if (go) {
                                    deleteTransfer(Id_Transfer, id_user);
                                }
                            });
                        });

                        deleteTransfer = (Id_Transfer, id_user) => {
                            fetch(`/Transfer/CancelarTransfer?Id_Transfer=${Id_Transfer}&id_user=${id_user}`)
                                .then(response => response.json())
                                .then(res => {
                                    if (res.error) {
                                        swal({
                                            title: "Ocurrió un error",
                                            text: "No fue posible cancelar el transfer. Si el error continúa, comuníquese con soporte técnico.",
                                            icon: "error",
                                        });
                                    } else {
                                        swal({
                                            text: "El transfer se ha cancelado correctamente.",
                                            icon: "success",
                                        }).then(() => {
                                            window.location.reload();
                                        });
                                    }
                                })
                                .catch(err => {
                                    swal({
                                        title: "Ocurrió un error",
                                        text: "No fue posible procesar la solicitud. Intente nuevamente más tarde.",
                                        icon: "error",
                                    });
                                });
                        };

                        $("#save-btn").click(() => {
                                swal({
                                    title: "¿Todo Listo?",
                                    icon: "warning",
                                    buttons: true,
                                    dangerMode: true,
                                }).then((go) => {
                                    if (go) {
                                        $("#Submit").click()
                                    }
                                });
                            }
                        );

                        //---------------------------------------------------------------- JSON --------------------------------------------------------


                        //--------------------------------------------------------------------------------------------------------------


                        $(document).ready(() => {
                            $("form").keypress((e) => {
                                if (e.which == 13) {
                                    return false;
                                }
                            });
                        });

                        var fecha = new Date();
                        var dia = String(fecha.getDate()).padStart(2, '0');
                        var mes = String(fecha.getMonth() + 1).padStart(2, '0');
                        var año = fecha.getFullYear();
                        var FechaMin = año + '-' + mes + '-' + dia


                        $("#FechaTransfer").attr('min', FechaMin);

                        $(document).ready(function () {
                            $("form").keypress(function (e) {
                                if (e.which == 13) {
                                    return false;
                                }
                            });
                        });

                        // $("#Layout_Aforos").attr("href", "../../Aforos");
                        // $("#Layout_NuevaReserva").attr("href", "../../Reservas/NuevaReserva");
                        // $("#Layout_VerReservas").attr("href", "../../Reservas/VerReservas");
                        // $("#Layout_NuevoTransfer").attr("href", "../../Transfer/NuevoTransfer");
                        // $("#Layout_VerTransfer").attr("href", "../../Transfer/VerTransfer");
